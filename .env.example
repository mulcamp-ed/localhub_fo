# ─────────────────────────────────────────────────────────────
# LocalHub 환경변수 예시 — 이 파일을 복사해 .env 로 만들어 사용하세요.
#   cp .env.example .env
# ⚠️ 아래 값들은 VITE_ 접두사가 없습니다 → 브라우저 번들에 노출되지 않고
#    Netlify Function(서버 측, netlify/functions/chat.js)에서만 사용됩니다.
#    .env 파일은 절대 커밋하지 마세요 (.gitignore 에 포함됨).
#    로컬에서 Function까지 테스트하려면 `netlify dev`로 실행하세요
#    (일반 `npm run dev`는 Vite 전용이라 Function이 동작하지 않습니다).
# ─────────────────────────────────────────────────────────────

# 챗봇용 OpenAI API 키. 비워두면 챗봇은 '로컬 검색 전용'으로 동작합니다.
OPENAI_API_KEY=

# OpenAI API Base URL (기본값 그대로 사용 권장)
OPENAI_BASE_URL=https://api.openai.com/v1

# 사용할 모델명 (OpenAI가 지원하는 모델)
OPENAI_MODEL=gpt-5-nano
