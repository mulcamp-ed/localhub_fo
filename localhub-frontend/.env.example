# ─────────────────────────────────────────────────────────────
# LocalHub 환경변수 예시 — 이 파일을 복사해 .env 로 만들어 사용하세요.
#   cp .env.example .env
# ⚠️ Vite의 VITE_ 접두사 값은 빌드 결과물(브라우저)에 그대로 노출됩니다.
#    반드시 "사용량 제한 / 결제 한도가 낮게 설정된 키"만 사용하세요.
#    .env 파일은 절대 커밋하지 마세요 (.gitignore 에 포함됨).
# ─────────────────────────────────────────────────────────────

# 챗봇용 LLM 게이트웨이 (GMS = OpenAI 호환 API). 비워두면 챗봇은 '로컬 검색 전용'으로 동작합니다.
VITE_GMS_API_KEY=

# OpenAI 호환 Base URL. GMS 게이트웨이 주소를 넣으세요.
# 예) https://gms.ssafy.io/gmsapi/api.openai.com/v1  또는  https://api.openai.com/v1
VITE_GMS_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1

# 사용할 모델명 (게이트웨이가 지원하는 모델)
VITE_GMS_MODEL=gpt-4o-mini
